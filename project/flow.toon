# weekly/flow | 100 func | 11 pipelines | 3 hub-types | 2026-03-08

PIPELINES[11] (Analysis:1, Core:2, Export:4, NLP:1, Unknown:3):
  Weekly [Export]: GitRepo → str
              → scan_repo(repo:GitRepo) → ScanResult    CC=8    IO ▶
              → _generate_repo_report(repo:GitRepo, result:ScanResult) → Path CC=31   IO  !!
              → generate_html_report(results:Dict[str, CheckResult], repo_info:RepoInfo, output_path:Union[str, Path], title:str) → None CC=4    IO
              → _render_html_template(template_name:str, context:Dict[str, Any]) → str CC=4    pure
              → _render_summary_report(context:Dict[str, Any]) → str CC=5    pure ■
              PURITY: 2/5 pure  BOTTLENECK: _generate_repo_report(CC=31)

  Weekly [Export]: ? → str
              → scan_all() → List[ScanResult]           CC=7    IO ▶
              → _generate_summary_report(results:List[ScanResult]) → Optional[Path] CC=13   mutation
              → generate_summary_report(repos:List[Dict[str, Any]], output_path:Union[str, Path], title:str, scan_date:Optional[str], since_date:Optional[str]) → None CC=2    IO
              → _render_html_template(template_name:str, context:Dict[str, Any]) → str CC=4    pure
              → _render_summary_report(context:Dict[str, Any]) → str CC=5    pure ■
              PURITY: 2/5 pure  BOTTLENECK: _generate_summary_report(CC=13)

  Weekly [Core]: Project → Dict[str, Any]
              → check(project:Project) → Optional[CheckResult] CC=8    mutation ▶
              → _detect_cd_config(project:Project) → Dict[str, Any] CC=15   pure  !!
              → _detect_ci_config(project:Project) → Dict[str, Any] CC=8    pure ■
              PURITY: 2/3 pure  BOTTLENECK: _detect_cd_config(CC=15)

  Weekly [NLP]: Project → str
              → check(project:Project) → Optional[CheckResult] CC=10   pure ▶
              → _get_dependencies(project:Project) → Dict[str, List[Tuple[str, str]]] CC=54   IO  !!
              → _normalize_constraint(constraint:str) → str CC=5    pure ■
              PURITY: 2/3 pure  BOTTLENECK: _get_dependencies(CC=54)

  Weekly [Unknown]: Project → Dict[str, List[Tuple[str, str]]]
              → check(project:Project) → Optional[CheckResult] CC=18   mutation  !! ▶
              → _detect_type_checkers(project:Project) → List[str] CC=9    mutation
              → _get_dependencies(project:Project) → Dict[str, List[Tuple[str, str]]] CC=1    pure ■
              PURITY: 1/3 pure  BOTTLENECK: check(CC=18)

  Weekly [Export]: Project → None
              → check(project:Project) → Optional[CheckResult] CC=1    mutation ▶
              → _run_mypy_check(path:Path) → None       CC=3    pure
              → _parse_mypy_output(output:str) → None   CC=12   mutation ■
              PURITY: 1/3 pure  BOTTLENECK: _parse_mypy_output(CC=12)

  Weekly [Unknown]: Project → Optional[str]
              → check(project:Project) → Optional[CheckResult] CC=15   mutation  !! ▶
              → _check_license(project:Project) → Dict[str, Any] CC=4    IO
              → _detect_license_type(content:str) → Optional[str] CC=15   pure  !! ■
              PURITY: 1/3 pure  BOTTLENECK: check(CC=15)

  Weekly [Core]: int → List[Dict[str, Any]]
              → to_json(indent:int) → str               CC=1    IO ▶
              → to_dict() → Dict[str, Any]              CC=2    pure
              → get_suggestions() → List[Dict[str, Any]] CC=3    mutation ■
              PURITY: 1/3 pure  BOTTLENECK: get_suggestions(CC=3)

  Weekly [Analysis]: datetime → str
              → analyze_changes(since_date:datetime) → ChangeSummary CC=9    pure ▶
              → get_commits_since(since_date:datetime) → List[CommitInfo] CC=10   mutation
              → _classify_commit(message:str) → str     CC=11   pure ■
              PURITY: 2/3 pure  BOTTLENECK: _classify_commit(CC=11)

  Weekly [Unknown]: ? → subprocess.CompletedProcess[str]
              → __post_init__() → None                  CC=15   mutation  !! ▶
              → _extract_metadata() → None              CC=10   mutation
              → _run_git(command:str) → subprocess.CompletedProcess[str] CC=2    pure ■
              PURITY: 1/3 pure  BOTTLENECK: __post_init__(CC=15)

  Weekly [Export]: Project → None
              → check(project:Project) → Optional[CheckResult] CC=1    mutation ▶
              → _run_black_check(path:Path) → None      CC=3    pure
              → _parse_black_output(output:str) → None  CC=6    mutation ■
              PURITY: 1/3 pure  BOTTLENECK: _parse_black_output(CC=6)


TRANSFORMS (fan-out ≥10):
  generate_llm_report(results:Dict[str, CheckResult], repo_info:RepoInfo, output_path:Union[str, Path], title:str) → None fan=33   !! mutation-heavy
  _generate_repo_report(repo:GitRepo, result:ScanResult) → Path fan=32   !! mutation-heavy
  scan_repo(repo:GitRepo) → ScanResult                    fan=30   !! mutation-heavy
  _find_common_issues(project:Project) → Dict[str, Any]   fan=26   !! side-effects
  scan_all() → List[ScanResult]                           fan=19   PIPELINE:GitScanner.entry
  analyze(project_path:Path, output_format:str, output:str, show_suggestions:bool, verbose:bool) → None fan=18   fan=18
  get_commits_since(since_date:datetime) → List[CommitInfo] fan=16   PIPELINE:GitChangeAnalyzer.entry
  generate_markdown_report(results:Dict[str, CheckResult], repo_info:RepoInfo, output_path:Union[str, Path], title:str) → None fan=16   PIPELINE:GitReportGenerator.entry
  scan(root_dir:Path, output_dir:Path, since_str:Optional[str], recursive:bool, jobs:int, output_format:str, summary_only:bool, verbose:bool) → int fan=15   fan=15
  analyze_project(project_path:Path) → Report             fan=15   fan=15
  generate_changelog_with_git_cliff(since_date:datetime, output_path:Path) → bool fan=14   PIPELINE:GitChangeAnalyzer.entry
  generate_html_report(results:Dict[str, CheckResult], repo_info:RepoInfo, output_path:Union[str, Path], title:str) → None fan=14   PIPELINE:GitReportGenerator.entry
  _generate_summary_report(results:List[ScanResult]) → Optional[Path] fan=14   PIPELINE:GitScanner.entry
  main() → None                                           fan=13   !! script-in-disguise
  _check_version_consistency(project:Project) → Dict[str, Any] fan=13   PIPELINE:ReleaseReadinessChecker.entry

CONTRACTS:
  Pipeline: Weekly
    scan_repo(repo:GitRepo) → ScanResult
      IN:  repo:GitRepo
      OUT: ScanResult
      SIDE-EFFECT: IO(mkdir, open, write)

    _generate_repo_report(repo:GitRepo, result:ScanResult) → Path
      IN:  repo:GitRepo, result:ScanResult
      OUT: Path
      SIDE-EFFECT: IO(mkdir, unlink)
      SMELL: CC=31 → split

    generate_html_report(results:Dict[str, CheckResult], repo_info:RepoInfo, output_path:Union[str, Path], title:str) → None
      IN:  results:Dict[str, CheckResult], repo_info:RepoInfo, output_path:Union[str, Path], title:str
      OUT: None
      SIDE-EFFECT: IO(mkdir, open, write)

    _render_html_template(template_name:str, context:Dict[str, Any]) → str
      IN:  template_name:str, context:Dict[str, Any]
      OUT: str

    _render_summary_report(context:Dict[str, Any]) → str
      IN:  context:Dict[str, Any]
      OUT: str

  Pipeline: Weekly
    scan_all() → List[ScanResult]
      IN:  ()
      OUT: List[ScanResult]
      SIDE-EFFECT: IO(mkdir)

    _generate_summary_report(results:List[ScanResult]) → Optional[Path]
      IN:  results:List[ScanResult]
      OUT: Optional[Path]
      SIDE-EFFECT: pure

    generate_summary_report(repos:List[Dict[str, Any]], output_path:Union[str, Path], title:str, scan_date:Optional[str], since_date:Optional[str]) → None
      IN:  repos:List[Dict[str, Any]], output_path:Union[str, Path], title:str, scan_date:Optional[str], since_date:Optional[str]
      OUT: None
      SIDE-EFFECT: IO(mkdir, open, write)

    _render_html_template(template_name:str, context:Dict[str, Any]) → str
      IN:  template_name:str, context:Dict[str, Any]
      OUT: str

    _render_summary_report(context:Dict[str, Any]) → str
      IN:  context:Dict[str, Any]
      OUT: str

  Pipeline: Weekly
    check(project:Project) → Optional[CheckResult]
      IN:  project:Project
      OUT: Optional[CheckResult]
      SIDE-EFFECT: pure
      INVARIANT: raises on invalid input

    _detect_cd_config(project:Project) → Dict[str, Any]
      IN:  project:Project
      OUT: Dict[str, Any]
      SMELL: CC=15 → split

    _detect_ci_config(project:Project) → Dict[str, Any]
      IN:  project:Project
      OUT: Dict[str, Any]

  Pipeline: Weekly
    check(project:Project) → Optional[CheckResult]
      IN:  project:Project
      OUT: Optional[CheckResult]
      INVARIANT: raises on invalid input

    _get_dependencies(project:Project) → Dict[str, List[Tuple[str, str]]]
      IN:  project:Project
      OUT: Dict[str, List[Tuple[str, str]]]
      SIDE-EFFECT: IO(read_text)
      SMELL: CC=54 → split

    _normalize_constraint(constraint:str) → str
      IN:  constraint:str
      OUT: str
      INVARIANT: len(output) <= len(input)

  Pipeline: Weekly
    check(project:Project) → Optional[CheckResult]
      IN:  project:Project
      OUT: Optional[CheckResult]
      SIDE-EFFECT: pure
      INVARIANT: raises on invalid input
      SMELL: CC=18 → split

    _detect_type_checkers(project:Project) → List[str]
      IN:  project:Project
      OUT: List[str]
      SIDE-EFFECT: pure
      INVARIANT: raises on invalid input

    _get_dependencies(project:Project) → Dict[str, List[Tuple[str, str]]]
      IN:  project:Project
      OUT: Dict[str, List[Tuple[str, str]]]

  Pipeline: Weekly
    check(project:Project) → Optional[CheckResult]
      IN:  project:Project
      OUT: Optional[CheckResult]
      SIDE-EFFECT: mutates self.issues
      INVARIANT: raises on invalid input

    _run_mypy_check(path:Path) → None
      IN:  path:Path
      OUT: None
      INVARIANT: raises on invalid input

    _parse_mypy_output(output:str) → None
      IN:  output:str
      OUT: None
      SIDE-EFFECT: pure

  Pipeline: Weekly
    check(project:Project) → Optional[CheckResult]
      IN:  project:Project
      OUT: Optional[CheckResult]
      SIDE-EFFECT: pure
      INVARIANT: raises on invalid input
      SMELL: CC=15 → split

    _check_license(project:Project) → Dict[str, Any]
      IN:  project:Project
      OUT: Dict[str, Any]
      SIDE-EFFECT: IO(read_text)
      INVARIANT: raises on invalid input

    _detect_license_type(content:str) → Optional[str]
      IN:  content:str
      OUT: Optional[str]
      SMELL: CC=15 → split

  Pipeline: Weekly
    to_json(indent:int) → str
      IN:  indent:int
      OUT: str
      SIDE-EFFECT: IO(dumps)

    to_dict() → Dict[str, Any]
      IN:  ()
      OUT: Dict[str, Any]

    get_suggestions() → List[Dict[str, Any]]
      IN:  ()
      OUT: List[Dict[str, Any]]
      SIDE-EFFECT: pure

  Pipeline: Weekly
    analyze_changes(since_date:datetime) → ChangeSummary
      IN:  since_date:datetime
      OUT: ChangeSummary

    get_commits_since(since_date:datetime) → List[CommitInfo]
      IN:  since_date:datetime
      OUT: List[CommitInfo]
      SIDE-EFFECT: pure

    _classify_commit(message:str) → str
      IN:  message:str
      OUT: str

  Pipeline: Weekly
    __post_init__() → None
      IN:  ()
      OUT: None
      SIDE-EFFECT: mutates self.path, self.org, self.last_commit_date
      SMELL: CC=15 → split

    _extract_metadata() → None
      IN:  ()
      OUT: None
      SIDE-EFFECT: mutates self.branch, self.remote_url, self.last_commit_date

    _run_git(command:str) → subprocess.CompletedProcess[str]
      IN:  command:str
      OUT: subprocess.CompletedProcess[str]

  Pipeline: Weekly
    check(project:Project) → Optional[CheckResult]
      IN:  project:Project
      OUT: Optional[CheckResult]
      SIDE-EFFECT: mutates self.issues
      INVARIANT: raises on invalid input

    _run_black_check(path:Path) → None
      IN:  path:Path
      OUT: None
      INVARIANT: raises on invalid input

    _parse_black_output(output:str) → None
      IN:  output:str
      OUT: None
      SIDE-EFFECT: pure


